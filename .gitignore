build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rutt-cache

# Optional stylelint cache
.stylelintcache

# lock file
package-lock.json
yarn.lock
pnpm-lock.yaml

